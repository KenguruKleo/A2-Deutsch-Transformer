# A2-Deutsch-Transformer — Local Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore — NEVER commit it.
#
# Real environment variables (exported in your shell) always take
# precedence over values in this file.

# ── OpenAI / OpenAI-compatible API ─────────────────────────────────────────
# Required only for: python -m src.data.generate_data --provider openai
OPENAI_API_KEY=sk-...

# Optional: override the default API endpoint (e.g. LM Studio, Azure, Groq)
# OPENAI_BASE_URL=http://localhost:1234/v1
